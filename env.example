# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file
# ─────────────────────────────────────────────

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Flask services (set per service or use a shared default)
FLASK_ENV=development
FLASK_DEBUG=1

# Payment gateway (mock/sandbox)
PAYMENT_GATEWAY_URL=https://sandbox.payment-gateway.com
PAYMENT_GATEWAY_API_KEY=your_sandbox_api_key_here

# Notification (email/SMS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Database URLs (one per service)
TUTOR_DB_URL=postgresql://user:password@localhost:5432/tutor_db
STUDENT_DB_URL=postgresql://user:password@localhost:5432/student_db
INTEREST_DB_URL=postgresql://user:password@localhost:5432/interest_db
BOOKING_DB_URL=postgresql://user:password@localhost:5432/booking_db

# KONG API Gateway
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000
