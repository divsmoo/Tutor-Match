{
  "title": "TutorMatch — Service Health",
  "uid": "tutormatch-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Services Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":0},{"color":"green","value":1}] },
          "mappings": [{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}]
        }
      },
      "targets": [{ "expr": "count(probe_success == 1)", "legendFormat": "Up", "datasource": "Prometheus" }],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Services Down",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"red","value":1}] }
        }
      },
      "targets": [{ "expr": "count(probe_success == 0) or vector(0)", "legendFormat": "Down", "datasource": "Prometheus" }],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Service Health Status",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "sortBy": [{ "displayName": "Service", "desc": false }] },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":0},{"color":"green","value":1}] },
          "mappings": [{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}],
          "custom": { "displayMode": "color-background" }
        },
        "overrides": [
          { "matcher": {"id":"byName","options":"instance"}, "properties": [{"id":"displayName","value":"Service"}] },
          { "matcher": {"id":"byName","options":"Value"}, "properties": [{"id":"displayName","value":"Status"}] }
        ]
      },
      "targets": [{ "expr": "probe_success", "legendFormat": "{{instance}}", "instant": true, "datasource": "Prometheus" }],
      "datasource": "Prometheus",
      "transformations": [{ "id": "labelsToFields", "options": {} }, { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true } } }]
    },
    {
      "id": 4,
      "title": "HTTP Probe Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"yellow","value":0.5},{"color":"red","value":1}] }
        }
      },
      "targets": [{ "expr": "probe_duration_seconds", "legendFormat": "{{instance}}", "datasource": "Prometheus" }],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Service Uptime % (last 30 min)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["mean"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":0},{"color":"yellow","value":0.9},{"color":"green","value":0.99}] }
        }
      },
      "targets": [{ "expr": "avg_over_time(probe_success[30m])", "legendFormat": "{{instance}}", "datasource": "Prometheus" }],
      "datasource": "Prometheus"
    }
  ]
}
